# ─────────────────────────────────────────────────────────────────────────────
# NEXT LEARNING PLATFORM — Environment Variables
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Local Development:
DATABASE_URL="postgresql://nextlearn:nextlearn_secret@localhost:5432/nextlearn_dev"
# Railway Example:
# DATABASE_URL="postgresql://postgres:PASSWORD@roundhouse.proxy.rlwy.net:PORT/railway"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-characters-long"
# Local Dev:
NEXTAUTH_URL="http://localhost:3000"
# Production (your Vercel URL):
# NEXTAUTH_URL="https://your-app.vercel.app"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── File Storage (optional, for course thumbnails) ──────────────────────────
# Cloudinary (recommended free tier)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Email (optional, for notifications) ─────────────────────────────────────
# Resend (recommended free tier - 3000 emails/month)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"
